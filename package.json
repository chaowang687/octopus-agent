{
  "name": "octopus-agent",
  "version": "0.1.1",
  "description": "Octopus Agent - 智能体编码工具",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "bash scripts/copy-bridge.sh && electron-vite dev -- --no-sandbox --disable-gpu-sandbox",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "jest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "docs": "node scripts/generate-docs.js",
    "docs:serve": "npx serve docs/api",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "install": "bash scripts/install.sh"
  },
  "build": {
    "appId": "com.octopus.agent",
    "productName": "Octopus Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "chaowang687",
      "repo": "octopus-agent"
    },
    "mac": {
      "icon": "build/icon.png",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "target": [
        "zip",
        "dmg"
      ]
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 190,
          "type": "file"
        },
        {
          "x": 410,
          "y": 190,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      },
      "title": "Octopus Agent v${version} 安装程序"
    }
  },
  "keywords": [
    "electron",
    "ai",
    "coding",
    "tool",
    "macos"
  ],
  "author": "Octopus Agent",
  "license": "MIT",
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "axios": "^1.6.0",
    "bcryptjs": "^3.0.3",
    "chalk": "^5.3.0",
    "chart.js": "^4.5.1",
    "commander": "^11.0.0",
    "electron-updater": "^6.0.0",
    "fs-extra": "^11.0.0",
    "inquirer": "^9.2.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "redux": "^4.2.0",
    "redux-thunk": "^2.4.0",
    "sharp": "^0.34.5",
    "systeminformation": "^5.20.0",
    "uuid": "^9.0.0",
    "vm2": "^3.10.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.0.0",
    "@types/inquirer": "^9.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^18.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^1.0.29",
    "eslint": "^8.0.0",
    "eslint-plugin-react": "^7.30.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typedoc": "^0.28.17",
    "typescript": "^5.0.0",
    "vite": "^4.0.0"
  }
}
